<Window x:Class="TouchpadVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="触控板可视化工具"
        Height="720" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="SidebarColumn" Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 侧边栏折叠按钮 ========== -->
        <Button x:Name="SidebarToggle"
                Grid.Column="0"
                Content="◀"
                Width="18"
                Height="40"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,-9,0"
                Background="#161b22"
                Foreground="#8b949e"
                BorderThickness="1"
                BorderBrush="#30363d"
                FontSize="12"
                Cursor="Hand"
                Click="SidebarToggle_Click"
                ToolTip="折叠侧边栏"
                Panel.ZIndex="10"/>

        <!-- ========== 左侧触控板可视化画布 ========== -->
        <Border Grid.Column="0"
                Background="#0d1117"
                BorderBrush="#30363d"
                BorderThickness="0,0,1,0">
            <Grid>
                <!-- 提示文字（无触控时显示） -->
                <TextBlock x:Name="HintText"
                           Text="在触控板上滑动手指 ✋"
                           Foreground="#484f58"
                           FontSize="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>

                <!-- 触控点画布 -->
                <Canvas x:Name="TouchCanvas"
                        Background="Transparent"/>
            </Grid>
        </Border>

        <!-- ========== 右侧信息面板 ========== -->
        <Grid Grid.Column="1" Background="#161b22">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="100"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- ===== 上半区：设备信息 + 触点数据（可整体滚动） ===== -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          x:Name="TopScrollViewer">
                <StackPanel Margin="12,10,12,10">

                    <!-- 标题 -->
                    <TextBlock Text="🖐 触控板可视化"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#e6edf3"/>
                    <TextBlock Text="Touchpad Visualizer"
                               FontSize="11" Foreground="#8b949e"
                               Margin="0,0,0,12"/>

                    <!-- 设备信息 + 复制按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📟 设备信息" FontSize="12"
                                   Foreground="#8b949e" VerticalAlignment="Center"/>
                        <Button x:Name="CopyBtn" Content="📋 复制"
                                FontSize="9" Height="20" Padding="5,0"
                                Margin="8,0,0,0" Background="#21262d"
                                Foreground="#c9d1d9" BorderThickness="1"
                                BorderBrush="#30363d" Cursor="Hand"
                                Click="CopyBtn_Click"/>
                        <Button x:Name="TouchpadToggleBtn" Content="🖐 启用"
                                FontSize="9" Height="20" Padding="5,0"
                                Margin="4,0,0,0" Background="#21262d"
                                Foreground="#c9d1d9" BorderThickness="1"
                                BorderBrush="#30363d" Cursor="Hand"
                                Click="TouchpadToggleBtn_Click"/>
                        <Button x:Name="MultiFingerBtn" Content="🔍 正常"
                                FontSize="9" Height="20" Padding="5,0"
                                Margin="4,0,0,0" Background="#21262d"
                                Foreground="#8b949e" BorderThickness="1"
                                BorderBrush="#30363d" Cursor="Hand"
                                Click="MultiFingerBtn_Click"
                                ToolTip="切换显示原始 HID 槽位数据"/>
                    </StackPanel>
                    <Border Background="#0d1117" BorderBrush="#30363d"
                            BorderThickness="1" CornerRadius="5" Padding="8,6"
                            Margin="0,0,0,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="100">
                            <TextBlock x:Name="DeviceInfo" Text="检测中..."
                                       Foreground="#c9d1d9" FontSize="10"
                                       TextWrapping="Wrap" FontFamily="Consolas"
                                       LineHeight="15"/>
                        </ScrollViewer>
                    </Border>

                    <!-- 实时数据 -->
                    <TextBlock Text="📊 实时数据" FontSize="12"
                               Foreground="#8b949e" Margin="0,0,0,4"/>
                    <Border Background="#0d1117" BorderBrush="#30363d"
                            BorderThickness="1" CornerRadius="5"
                            Padding="10,6" Margin="0,0,0,6">
                        <TextBlock x:Name="TouchCount" Text="触点数量：0"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#58a6ff"/>
                    </Border>

                    <Separator BorderBrush="#21262d" Margin="0,4,0,6"/>

                    <!-- 触点详情 -->
                    <TextBlock Text="📍 触点详情" FontSize="12"
                               Foreground="#8b949e" Margin="0,0,0,4"/>
                    <ItemsControl x:Name="TouchList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0d1117" BorderBrush="#30363d"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="6,4" Margin="0,1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{Binding Color}"
                                                     Margin="0,2,5,2"/>
                                            <TextBlock Text="{Binding DisplayId}"
                                                       FontWeight="Bold"
                                                       Foreground="#e6edf3" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding PositionText}"
                                                   Foreground="#8b949e" FontSize="10"/>
                                        <TextBlock Text="{Binding RawText}"
                                                   Foreground="#e3b341" FontSize="9"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Text="{Binding SizeText}"
                                                   Foreground="#8b949e" FontSize="10"/>
                                        <TextBlock Text="{Binding PressureText}"
                                                   Foreground="#8b949e" FontSize="10"/>
                                        <TextBlock Text="{Binding SourceText}"
                                                   Foreground="#58a6ff" FontSize="9"
                                                   FontStyle="Italic"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== GridSplitter（可拖拽分隔栏） ===== -->
            <GridSplitter Grid.Row="1"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          Background="#21262d"
                          BorderBrush="#30363d"
                          BorderThickness="0,1"
                          ShowsPreview="False"
                          Cursor="SizeNS"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ===== 下半区：调试日志 ===== -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,6,12,2">
                    <TextBlock Text="📋 调试日志" FontSize="12"
                               Foreground="#8b949e" VerticalAlignment="Center"/>
                    <TextBlock x:Name="_debugCounter"
                               Text="  |  消息:0  触控帧:0"
                               Foreground="#e3b341" FontSize="10"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              x:Name="DebugScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Margin="12,0,12,6">
                    <ItemsControl x:Name="DebugList" FontSize="9">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas" FontSize="9"
                                           Foreground="#8b949e"
                                           TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>
